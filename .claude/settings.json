{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "sh hooks/post-edit.sh claude" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "sh hooks/stop.sh claude" }]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "sh hooks/session-start.sh claude" }
        ]
      }
    ]
  }
}
