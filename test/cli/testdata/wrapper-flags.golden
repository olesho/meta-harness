--effort <string> = "" : reasoning effort for supported harnesses (low, medium, high, xhigh, max)
--model <string> = "" : model id for supported harnesses (claude --model, codex -c model)
--tmux-child <string> = "" : internal: in-pane re-exec marker; do not set manually
--tmux-session <string> = "" : spawn the run inside a detached tmux session named mh-<value> and exit immediately
--trace-file <string> = "" : path to write trace events as NDJSON (default: trace events are dropped)
--trace-stderr <bool> = "false" : write trace events as NDJSON to stderr (mutually exclusive with --trace-file)
