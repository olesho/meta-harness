# Orche / fleet-db config for this project. Copy to `.env` (gitignored) and fill
# in secrets — this file is the committed template so tuned values survive a
# fresh `orche init` or a deleted local `.env`.
ORCHE_WORKSPACE=META-HARNESS
ORCHE_FLEET_URL=http://fleet-db.localhost/
# ORCHE_ACTOR=your-name
# Event-bus transport: fleet-db native per-workspace pub/sub (ORCHE-76). Flipped
# 2026-07-04. Revert = remove this line (or =file) and restart this supervisor.
ORCHE_QUEUE_BACKEND=fleet
ORCHE_RELEASE_WATCH=1
ORCHE_RELEASE_REDEPLOY=in-place
ORCHE_OTEL=file
# Release gate: this project runs its tests on Node via vitest (`npm test` →
# `vitest run`) instead of orche's default `bun run test:e2e:ultimate`. Migrated
# off `bun test` (META-HARNESS-30..36); restart the supervisor to reload this.
ORCHE_RELEASE_GATE_CMD=npm test
# On-demand dev->main release gate kick (loopback only): POST http://127.0.0.1:53999/release/fire
ORCHE_RELEASE_FIRE_PORT=53999
# Per-run deadline for `harness-wrapper run` (worker harness runs). Source
# default is 15m (src/cli/run.ts), too short for this project's larger phase
# tickets. Bumped 15m→45m→90m: 45m was blown through by META-HARNESS-44
# (env-lifecycle refactor + new live-e2e test file + goldens + docs + dist
# rebuild), which timed out 3 consecutive worker runs and got auto-blocked by
# the runaway guard (context deadline exceeded). Restart the supervisor after
# changing this so it reloads.
HARNESS_WRAPPER_RUN_TIMEOUT=90m
DAYTONA_API_KEY=your-daytona-api-key-here
